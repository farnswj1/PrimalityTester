{
  "compilerOptions": {
    "types": ["node", "jest"],
    "module": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
